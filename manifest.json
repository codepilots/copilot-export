{
  "manifest_version": 3,
  "name": "Copilot Chat Exporter",
  "version": "1.0.0",
  "description": "Export full Microsoft 365 Copilot chat conversations to Markdown, JSON, or plain text.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Export Copilot Chat",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://copilot.microsoft.com/*",
    "https://m365.cloud.microsoft/*",
    "https://www.microsoft365.com/*",
    "https://*.sharepoint.com/*",
    "https://teams.microsoft.com/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://designerapp.officeapps.live.com/*"
  ]
}
